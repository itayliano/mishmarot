{
  "name": "mishmarot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Upload a shift-schedule PDF, detect shifts (Hebrew/English), and add them to Google Calendar.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "selftest": "tsx scripts/selftest.ts",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -t -b gh-pages"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
